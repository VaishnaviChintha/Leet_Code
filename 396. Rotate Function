import java.util.*;
class Solution {
    public int maxRotateFunction(int[] nums) {
        int sum=0;
        int n = nums.length;
        int f=0;
        for(int i=0;i<n;i++){
            sum+=nums[i];
            f+=i*nums[i];
        }
        int maxValue=f;
        for(int i=1;i<n;i++){
            f=f+sum-(n*nums[n-i]);
            maxValue = Math.max(maxValue,f);
        }
        return maxValue;
    }
public static void main(String[] args) {
        Solution sol = new Solution();
        int[] nums1 = {4, 3, 2, 6};
        System.out.println("Output: " + sol.maxRotateFunction(nums1)); // 26
        int[] nums2 = {100};
        System.out.println("Output: " + sol.maxRotateFunction(nums2)); // 0
        int[] nums3 = {1, 2, 3, 4};
        System.out.println("Output: " + sol.maxRotateFunction(nums3)); // 20
    }
}
