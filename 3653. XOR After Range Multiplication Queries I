import java.util.*;
class Solution {
    public int xorAfterQueries(int[] nums, int[][] queries) {
        for(int i=0;i<queries.length;i++){
            int left=queries[i][0];
            int right=queries[i][1];
            int step = queries[i][2];
            int val = queries[i][3];
            while(left<=right){
                nums[left] = (int)((nums[left] * 1L * val) % 1000000007);
                left+=step;
            }
        }
        int xor=0;
        for(int i=0;i<nums.length;i++){
            xor^=nums[i];
        }
        return xor;
    }
public static void main(String[] args) {
        Solution sol = new Solution();

        // Example input
        int[] nums = {1, 2, 3, 4, 5};

        int[][] queries = {
            {0, 4, 1, 2},  // multiply all elements by 2
            {1, 3, 1, 3},  // multiply index 1 to 3 by 3
            {0, 4, 2, 2}   // multiply every 2nd element by 2
        };

        int result = sol.xorAfterQueries(nums, queries);

        System.out.println("Final XOR: " + result);

        // Optional: print modified array
        System.out.println("Modified array: " + Arrays.toString(nums));
    }
}
