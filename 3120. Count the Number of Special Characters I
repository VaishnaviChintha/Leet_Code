import java.util.*;
class Solution {
    public int numberOfSpecialChars(String word) {
        int[] upper = new int[26];
        int[] lower = new int[26];
        for(char ch : word.toCharArray()){
            if(Character.isLowerCase(ch)){
                lower[ch-'a']++;
            }else{
                upper[ch-'A']++;
            }
        }
        int count=0;
        for(int i=0;i<26;i++){
            if(lower[i]!=0 && upper[i]!=0){
                count++;
            }
        }
        return count;
    }
public static void main(String[] args) {

        Solution obj = new Solution();

        String word1 = "aaAbBc";
        String word2 = "abc";
        String word3 = "aAAbBBcC";

        System.out.println(obj.numberOfSpecialChars(word1));
        System.out.println(obj.numberOfSpecialChars(word2));
        System.out.println(obj.numberOfSpecialChars(word3));
    }
}
