import java.util.*;
class Solution {
    public int longestSubarray(int[] nums) {
        int maxSize=0;
        for(int i=0;i<nums.length;i++){
            boolean flag=false;
            int  j=i,size=0;
            while(j<nums.length){
                if(nums[j]==1){
                    size++;
                }else if(nums[j]==0 && !flag){
                    flag=true;
                    size++;
                }else if(nums[j]==0 && flag){
                         break;
                }
                j++;
            }
            maxSize=Math.max(maxSize,size-1);
        }
        return maxSize;
    }
public static void main(String[] args) {
        Solution sol = new Solution();

        // Test case 1
        int[] nums1 = {1, 1, 0, 1};
        System.out.println("Output: " + sol.longestSubarray(nums1)); // Expected: 3
}
}
