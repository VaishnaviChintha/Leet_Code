import java.util.*;
class Solution {
    public int numberOfArithmeticSlices(int[] nums) {
        if(nums.length<3){
            return 0;
        }
       int count=0;
       for(int i=0;i<=nums.length-3;i++){
        int diff =nums[i+1]-nums[i];
        int size=1;
        for(int j=i+1;j<nums.length;j++){
            if(nums[j]-nums[j-1]==diff){
                size++;
            }else{
                break;
            }
            if(size>=3){
               count++;
            }
        }
       } 
       return count;
    }
 public static void main(String[] args) {
        Solution sol = new Solution();

        // Test case 1
        int[] nums1 = {1, 2, 3, 4};
        System.out.println("Output: " + sol.numberOfArithmeticSlices(nums1)); // Expected: 3

        // Test case 2
        int[] nums2 = {1, 3, 5, 7, 9};
        System.out.println("Output: " + sol.numberOfArithmeticSlices(nums2)); // Expected: 6
}
}
