import java.util.*;
 public class TreeNode {
       int val;
       TreeNode left;
       TreeNode right;
       TreeNode() {}
       TreeNode(int val) { this.val = val; }
       TreeNode(int val, TreeNode left, TreeNode right) {
           this.val = val;
           this.left = left;
           this.right = right;
}
}
class Solution {
    public TreeNode constructMaximumBinaryTree(int[] nums) {
       if(nums.length==0) return null;
       return build(nums,0,nums.length);
    }
    private static TreeNode build(int[]nums,int l,int r){
        if(l>=r){
            return null;
        }
        int max_idx = l;
        for(int i=l;i<r;i++){
            if(nums[i]>nums[max_idx]){
                max_idx=i;
            }
        }
        TreeNode node = new TreeNode(nums[max_idx]);
        node.left=build(nums,l,max_idx);
        node.right=build(nums,max_idx+1,r);
        return node;
    }
public void preorder(TreeNode root) {
        if (root == null) return;
        System.out.print(root.val + " ");
        preorder(root.left);
        preorder(root.right);
    }

}
public class Main {
    public static void main(String[] args) {
        int[] nums = {3, 2, 1, 6, 0, 5};
        Solution sol = new Solution();
        TreeNode root = sol.constructMaximumBinaryTree(nums);

        System.out.print("Preorder traversal of Maximum Binary Tree: ");
        sol.preorder(root);  // Output should show the tree structure in preorder
    }
}
