import java.util.*;
class Solution {
    public int removeDuplicates(int[] nums) {
        int left=0;
        int idx=0;
        int n = nums.length;
        while(left<n){
            int right = left;
            while(right<n-1 && nums[left]==nums[right+1]){
                right++;
            }
            if((right-left+1)==1){
                nums[idx++]=nums[left];
            }else{
                nums[idx++]=nums[left];
                nums[idx++]=nums[left];
            }
            left = right+1;
        }

        return idx;
    }
public static void main(String[] args) {
        Solution sol = new Solution();

        int[] nums1 = {1, 1, 1, 2, 2, 3};
        int[] nums2 = {0, 0, 1, 1, 1, 1, 2, 3, 3};
        int[] nums3 = {1, 2, 3};
        int[] nums4 = {1, 1, 1, 1};

        test(nums1, sol);
        test(nums2, sol);
        test(nums3, sol);
        test(nums4, sol);
    }

    public static void test(int[] nums, Solution sol) {
        int len = sol.removeDuplicates(nums);
        
        System.out.print("Length: " + len + " | Array: ");
        for (int i = 0; i < len; i++) {
            System.out.print(nums[i] + " ");
        }
        System.out.println();
    }
}
