import java.util.*;
class Solution {
    public int minPartitions(String n) {
         int maxDigit = 0;
        for (int i=0;i<n.length(); i++) {
            int digit = n.charAt(i)-'0';
            maxDigit = Math.max(maxDigit,digit);
        }
        return maxDigit;
    }
 public static void main(String[] args) {
        String n1 = "32";
        String n2 = "82734";
        String n3 = "27346209830709182346";

        System.out.println(minPartitions(n1)); // Output: 3
        System.out.println(minPartitions(n2)); // Output: 8
        System.out.println(minPartitions(n3)); // Output: 9
    }
}
