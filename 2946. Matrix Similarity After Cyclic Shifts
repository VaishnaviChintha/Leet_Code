import java.util.*;
class Solution {
    public boolean areSimilar(int[][] mat, int k) {
        int m=mat.length;
        int n = mat[0].length;
        k=k%n;
        for(int i=0;i<m;i++){
           
            for(int j=0;j<n;j++){
                 int newIdx = 0;
                if(i%2==0){
                    newIdx=(j+k)%n;
                }else{
                    newIdx=(j-k+n)%n;
                }
                if(mat[i][j]!=mat[i][newIdx]){
                return false;
            }
            }
        }
        return true;
    }
 public static void main(String[] args) {
        Solution obj = new Solution();

        int[][] mat = {
            {1, 2, 1, 2},
            {5, 5, 5, 5},
            {6, 3, 6, 3}
        };

        int k = 2;

        boolean result = obj.areSimilar(mat, k);

        System.out.println("Are matrices similar? " + result);
    }
}
